<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.ebi.ac.uk/testcases/inter-ontology/b#"
     xml:base="http://www.ebi.ac.uk/testcases/inter-ontology/b"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

    <owl:Ontology rdf:about="http://www.ebi.ac.uk/testcases/inter-ontology/b"/>

    <!-- ClassB is defined in this ontology -->
    <owl:Class rdf:about="http://www.ebi.ac.uk/testcases/inter-ontology/b#ClassB">
        <rdfs:label>Class B</rdfs:label>
    </owl:Class>

</rdf:RDF>
