#!/bin/bash

echo Loading data...
./create_datafiles.sh file://$(find /mnt/config -type f) /tmp/out /mnt/embeddings $@
./load_into_neo4j.sh /opt/neo4j /tmp/out
sleep 20
./create_neo4j_indexes.sh /opt/neo4j
rm -rf /opt/solr/server/solr/*
cp -r /opt/ols/dataload/solr_config/* /opt/solr/server/solr/
./load_into_solr.sh /opt/solr /tmp/out
chmod -R 777 /opt/solr/server/solr/*
chmod -R 777 /opt/neo4j/data/*



